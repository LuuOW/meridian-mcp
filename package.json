{
  "name": "meridian-skills-mcp",
  "version": "2.2.2",
  "description": "Self-contained MCP for the Meridian orbital skill router (stdio + HTTP/Streamable transports — Grok / ChatGPT / Claude compatible). Generates candidate skills with Llama-3.3-70B (via GitHub Models) and ranks them with a local orbital classifier (planet/moon/trojan/asteroid/comet/irregular). No backend required.",
  "type": "module",
  "bin": {
    "meridian-mcp":      "./mcp/index.mjs",
    "meridian-mcp-http": "./mcp/http.mjs"
  },
  "main": "./mcp/index.mjs",
  "files": [
    "mcp",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "stdio": "node mcp/index.mjs",
    "http":  "node mcp/http.mjs",
    "test":  "node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "skills",
    "routing",
    "orbital",
    "claude",
    "cursor",
    "windsurf",
    "grok",
    "streamable-http",
    "remote-mcp"
  ],
  "author": "Meridian <hello@ask-meridian.uk>",
  "license": "MIT",
  "homepage": "https://ask-meridian.uk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LuuOW/meridian-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/LuuOW/meridian-mcp/issues"
  },
  "mcpName": "io.github.LuuOW/meridian-skills"
}
